# =============================================================================
# PageManager — Variáveis de Ambiente (Desenvolvimento Local)
# =============================================================================
# Copie para .env e preencha com seus valores reais
# NUNCA comite o arquivo .env

# n8n
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=SENHA_FORTE_AQUI
N8N_ENCRYPTION_KEY=CHAVE_32_BYTES_HEX_AQUI
GENERIC_TIMEZONE=America/Sao_Paulo

# Banco local (PostgreSQL Docker) — padrão para desenvolvimento
DB_LOCAL_PASSWORD=n8npassword

# Neon — descomente e preencha para testar com o banco de produção
# USE_NEON=true
# NEON_DB_HOST=ep-SEU-ENDPOINT.us-east-2.aws.neon.tech
# NEON_DB_NAME=neondb
# NEON_DB_USER=SEU_USUARIO_NEON
# NEON_DB_PASSWORD=SEU_PASSWORD_NEON

# Google Gemini
GEMINI_API_KEY=AIzaSy_SEU_GEMINI_KEY_AQUI
# Modelo na URL dos nodes Gemini: gemini-2.5-flash (ou gemini-1.5-flash se 404)

# OpenAI / DALL-E
OPENAI_API_KEY=sk-SEU_OPENAI_KEY_AQUI
DALLE_MODEL=dall-e-3
DALLE_SIZE=1024x1024

# LinkedIn — Perfil pessoal (get_linkedin_token.py)
LINKEDIN_ACCESS_TOKEN=AQX_SEU_TOKEN_AQUI
LINKEDIN_MEMBER_URN=urn:li:person:SEU_SUB_AQUI
